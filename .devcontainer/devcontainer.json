{
  "name": "Schenberg Risk Toolkit",
  "build": {
    "dockerfile": "../containers/Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspace/risk-toolkit",
  "customizations": {
    "vscode": {
      "extensions": [
        "charliermarsh.ruff",
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspace/risk-toolkit/.venv/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests"]
      }
    }
  },
  "postCreateCommand": "uv sync --all-groups --all-extras --workspace",
  "remoteUser": "vscode"
}
