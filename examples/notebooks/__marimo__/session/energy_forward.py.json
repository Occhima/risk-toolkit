            "text/plain": ""
          }
        }
      ],
      "console": []
    },
    {
      "id": "bkHC",
      "code_hash": "5b7ce70fb8bb2a9fb2bc37a00d12d1d5",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"market-requirements\">Market requirements</h2>\n<span class=\"paragraph\">Each field names a market column the instrument exposes and the keyed read that fills it. <code>.by(...)</code> is omitted here \u2014 the reads use their typed default keys.</span>\n<ul>\n<li><strong>forward_price</strong> \u27f5 <code>energy_forward_curve(submarket, delivery_period)</code></li>\n<li><strong>zero_rate</strong> \u27f5 <code>di_curve(id_indexador, payment_days)</code></li>\n<li><strong>fx_rate</strong> \u27f5 <code>fx_rates(currency)</code></li>\n</ul></span>"
          }
        }
      ],
      "console": []
    },
    {
      "id": "lEQa",
      "code_hash": "55134f12c62b001882f2ddef92762d85",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"the-pricing-graph\">The pricing graph</h2>\n<div class=\"language-splus codehilite\"><pre><span></span><code><span class=\"n\">FormulaGraph</span><span class=\"w\"> </span><span class=\"n\">energy_forward</span>\n\n<span class=\"n\">View</span><span class=\"o\">:</span>\n\n<span class=\"w\">    </span><span class=\"o\">-</span><span class=\"w\"> </span><span class=\"n\">output</span><span class=\"w\"> </span><span class=\"o\">-&gt;</span><span class=\"w\"> </span><span class=\"n\">ForwardPricing</span>\n\n<span class=\"n\">Inputs</span><span class=\"o\">:</span><span class=\"w\"> </span><span class=\"n\">currency</span><span class=\"p\">,</span><span class=\"w\"> </span><span class=\"n\">delivery_period</span><span class=\"p\">,</span><span class=\"w\"> </span><span class=\"n\">id_indexador</span><span class=\"p\">,</span><span class=\"w\"> </span><span class=\"n\">payment_days</span><span class=\"p\">,</span><span class=\"w\"> </span><span class=\"n\">strike</span><span class=\"p\">,</span><span class=\"w\"> </span><span class=\"n\">submarket</span>\n\n<span class=\"n\">Market</span><span class=\"w\"> </span><span class=\"n\">reads</span><span class=\"o\">:</span>\n\n<span class=\"w\">    </span><span class=\"o\">-</span><span class=\"w\"> </span><span class=\"n\">forward_price</span><span class=\"w\"> </span><span class=\"o\">&lt;-</span><span class=\"w\"> </span><span class=\"nf\">energy_forward_curve</span><span class=\"p\">(</span><span class=\"n\">submarket</span><span class=\"p\">,</span><span class=\"w\"> </span><span class=\"n\">delivery_period</span><span class=\"p\">)</span>\n\n<span class=\"w\">    </span><span class=\"o\">-</span><span class=\"w\"> </span><span class=\"n\">zero_rate</span><span class=\"w\"> </span><span class=\"o\">&lt;-</span><span class=\"w\"> </span><span class=\"nf\">di_curve</span><span class=\"p\">(</span><span class=\"n\">id_indexador</span><span class=\"p\">,</span><span class=\"w\"> </span><span class=\"n\">payment_days</span><span class=\"p\">)</span>\n\n<span class=\"w\">    </span><span class=\"o\">-</span><span class=\"w\"> </span><span class=\"n\">fx_rate</span><span class=\"w\"> </span><span class=\"o\">&lt;-</span><span class=\"w\"> </span><span class=\"nf\">fx_rates</span><span class=\"p\">(</span><span class=\"n\">currency</span><span class=\"p\">)</span>\n\n<span class=\"n\">Formulas</span><span class=\"o\">:</span>\n\n<span class=\"w\">    </span><span class=\"o\">-</span><span class=\"w\"> </span><span class=\"bp\">T</span><span class=\"w\"> </span><span class=\"o\">=</span><span class=\"w\"> </span>\\<span class=\"n\">frac</span><span class=\"p\">{</span><span class=\"n\">d</span><span class=\"p\">}{</span><span class=\"m\">252</span><span class=\"p\">}</span><span class=\"w\">  </span><span class=\"c1\"># 252-day year fraction (time to maturity).</span>\n\n<span class=\"w\">    </span><span class=\"o\">-</span><span class=\"w\"> </span><span class=\"n\">DF</span><span class=\"w\"> </span><span class=\"o\">=</span><span class=\"w\"> </span><span class=\"n\">e</span><span class=\"o\">^</span><span class=\"p\">{</span><span class=\"o\">-</span><span class=\"n\">rT</span><span class=\"p\">}</span><span class=\"w\">  </span><span class=\"c1\"># Continuously compounded discount factor off the zero curve.</span>\n\n<span class=\"w\">    </span><span class=\"o\">-</span><span class=\"w\"> </span><span class=\"n\">future_value</span><span class=\"w\"> </span><span class=\"o\">=</span><span class=\"w\"> </span>\\<span class=\"n\">operatorname</span><span class=\"p\">{</span><span class=\"n\">future_value</span><span class=\"p\">}(</span><span class=\"n\">forward_price</span><span class=\"p\">,</span><span class=\"w\"> </span><span class=\"n\">strike</span><span class=\"p\">)</span><span class=\"w\">  </span><span class=\"c1\"># Generic forward unit payoff.</span>\n\n<span class=\"w\">    </span><span class=\"o\">-</span><span class=\"w\"> </span><span class=\"n\">PV</span><span class=\"w\"> </span><span class=\"o\">=</span><span class=\"w\"> </span><span class=\"n\">V</span><span class=\"w\"> </span>\\<span class=\"n\">cdot</span><span class=\"w\"> </span><span class=\"n\">DF</span><span class=\"w\">  </span><span class=\"c1\"># Discount a future cashflow into local present value.</span>\n\n<span class=\"w\">    </span><span class=\"o\">-</span><span class=\"w\"> </span><span class=\"n\">value</span><span class=\"w\"> </span><span class=\"o\">=</span><span class=\"w\"> </span>\\<span class=\"n\">operatorname</span><span class=\"p\">{</span><span class=\"n\">value</span><span class=\"p\">}(</span><span class=\"n\">present_value</span><span class=\"p\">,</span><span class=\"w\"> </span><span class=\"n\">fx_rate</span><span class=\"p\">)</span><span class=\"w\">  </span><span class=\"c1\"># Translate local PV to reporting currency.</span>\n\n<span class=\"n\">Returns</span><span class=\"o\">:</span>\n\n<span class=\"w\">    </span><span class=\"o\">-</span><span class=\"w\"> </span><span class=\"n\">future_value</span><span class=\"w\"> </span><span class=\"o\">&lt;-</span><span class=\"w\"> </span><span class=\"n\">future_value</span>\n\n<span class=\"w\">    </span><span class=\"o\">-</span><span class=\"w\"> </span><span class=\"n\">present_value</span><span class=\"w\"> </span><span class=\"o\">&lt;-</span><span class=\"w\"> </span><span class=\"n\">present_value</span>\n\n<span class=\"w\">    </span><span class=\"o\">-</span><span class=\"w\"> </span><span class=\"n\">value</span><span class=\"w\"> </span><span class=\"o\">&lt;-</span><span class=\"w\"> </span><span class=\"n\">value</span>\n</code></pre></div></span>"
          }
        }
      ],
      "console": []
    },
